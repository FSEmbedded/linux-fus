				"ETH_A_RGMII_TXC", "ETH_A_RGMII_RXCTL",
	/* 25-29 */ "ETH_A_RGMII_RXC", "ETH_A_RGMII_RXD0", "ETH_A_RGMII_RXD1",
				"ETH_A_RGMII_RXD2", "ETH_A_RGMII_RXD3",
	/* 30-31 */ "", "";
	status = "okay";
};

&gpio2 {
	gpio-line-names =
	/* 0-4 */   "SD_eMMC_CLK", "SD_eMMC_CMD", "SD_eMMC_D0", "SD_eMMC_D1",
				"SD_eMMC_D2",
	/* 5-9 */   "SD_eMMC_D3", "SD_eMMC_D4", "SD_eMMC_D5", "SD_eMMC_D6",
				"SD_eMMC_D7",
	/* 10-14 */ "SD_eMMC_RST", "SD_eMMC_DS", "SD_B_CD", "SD_B_CLK", "SD_B_CMD",
	/* 15-19 */ "SD_B_D0", "SD_B_D1", "SD_B_D2", "SD_B_D3", "SD_B_PWR_EN_3V3", //HIER NOCHMAL FRAGEN
	/* 20-24 */ "SD_B_WP", "", "", "", "",
	/* 25-29 */ "", "", "", "", "",
	/* 30-31 */ "", "";
