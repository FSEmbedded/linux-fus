	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_usb3_0_pwr>;
	dr_mode = "otg";
	hnp-disable;
	srp-disable;
	adp-disable;
	usb-role-switch;
	role-switch-default-mode = "none";
	status = "okay";

	port {
		usb3_drd_sw: endpoint {
			remote-endpoint = <&connector_dr_sw>;
		};
	};
};
