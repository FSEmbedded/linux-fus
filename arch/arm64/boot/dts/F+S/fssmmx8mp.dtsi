	gpio-line-names =
	/* 0-4 */   "SE050_ENA", "WDT_TIME_OUT", "PMIC_WDOG", "SPI_B_CS1", "SD_VSEL",  //DIE ZWEI SACHEN FRAGEN
	/* 5-9 */   "GPIO2", "ETH_A_PHY_IRQ", "GPIO1", "GPIO3", "GPIO0",
	/* 10-14 */ "USB_A_ID", "GPIO7", "USB_A_PWREN_1V8", "USB_A_OC#_1V8",
				"USB_B_PWREN_1V8",
	/* 15-19 */ "USB_B_OC#_1V8", "ETH_A_RGMII_MDC", "ETH_A_RGMII_MDIO",
				"ETH_A_RGMII_TXD3", "ETH_A_RGMII_TXD2",
