};

&gpio3 {
	gpio-line-names =
	/* 0-4 */   "I2S_B_CLK", "I2S_B_SDOUT", "I2C_PM_SCL", "I2C_PM_SDA", "GPIO8",
	/* 5-9 */   "GPIO9", "I2S_B_SDIN", "I2S_B_LRCLK", "UART_D_RTS", "UART_D_CTS",
	/* 10-14 */ "SD_WLAN_D0", "SD_WLAN_D1", "SD_WLAN_D2", "SD_WLAN_D3", "GPIO12",
	/* 15-19 */ "GPIO10", "GPIO11", "SD_WLAN_CLK", "SD_WLAN_CMD", "I2C_INT_SCL",
	/* 20-24 */ "I2C_INT_SDA", "LVDS_B_BL_PWM", "CAN_A_TX", "CAN_A_RX",
				"CAN_B_TX",
	/* 25-29 */ "CAN_B_RX", "I2C_HDMI_SCL", "I2C_HDMI_SDA", "GPIO13", "HDMI_HPD",
	/* 30-31 */ "", "";
	status = "okay";
};

&gpio4 {
	gpio-line-names =
	/* 0-4 */   "RESET_OUT", "DISP_A_BL_EN", "LVDS_B_VDD_EN", "LVDS_B_BL_EN",
