#ifdef CONFIG_IMX93_DISPLAY
&parallel_disp_fmt {
	fsl,interface-pix-fmt = "rgb666";
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_lcdif>;

	ports {
		port@1 {
			reg = <1>;
			display_out: endpoint {
				remote-endpoint = <&panel_in>;
			};
		};
	};
